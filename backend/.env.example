# ================================================
# 🔧 CONFIGURAÇÃO DO SERVIDOR ECOBOT
# ================================================

# Porta onde o servidor vai rodar
PORT=3001

# ================================================
# 📧 CREDENCIAIS GMAIL (OBRIGATÓRIO)
# ================================================

# Seu email do Gmail
EMAIL_USER=seu-email@gmail.com

# Sua senha de app (NÃO é a senha normal do Gmail!)
# Para obter:
# 1. Acesse: https://myaccount.google.com/apppasswords
# 2. Selecione: Mail e Windows (ou seu dispositivo)
# 3. Copie a senha de 16 caracteres gerada
# Exemplo: xyzw abcd efgh ijkl
EMAIL_PASS=sua-senha-app-de-16-caracteres

# ================================================
# 🔗 CREDENCIAIS TAGO.IO (OPCIONAL)
# ================================================

# Sua chave de API do Tago.io
TAGO_API_KEY=sua-chave-api-tago

# ================================================
# 🌍 AMBIENTE
# ================================================

# development = modo desenvolvimento
# production = modo produção
NODE_ENV=development
