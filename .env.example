# ================================================
# 🔧 CONFIGURAÇÃO DO SERVIDOR ECOBOT
# ================================================

# Porta onde o servidor vai rodar
PORT=3001

# ================================================
# 📧 CREDENCIAIS GMAIL (OBRIGATÓRIO)
# ================================================

# Seu email do Gmail
EMAIL_USER=seu-email@gmail.com

# Sua senha de app (NÃO é a senha normal do Gmail!)
# Gere em: https://myaccount.google.com/apppasswords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ================================================
# 🔐 TAGO.IO TOKENS (OPCIONAL)
# ================================================

# Token da primeira base de monitoramento
TAGO_TOKEN_1=seu-token-aqui

# Token da segunda base de monitoramento (se existir)
TAGO_TOKEN_2=outro-token-aqui

# ================================================
# 📧 DESTINATÁRIOS DE ALERTA (OPCIONAL)
# ================================================

# Emails separados por vírgula que receberão alertas
ALERT_EMAILS=email1@example.com,email2@example.com

# ================================================
# 🔗 CORS (OPCIONAL)
# ================================================

# URLs permitidas para fazer requisições (separadas por vírgula)
# Se vazio, usa defaults: localhost:3000, localhost:8080
CORS_ORIGINS=https://seu-dominio.com,https://outro-dominio.com

# ================================================
# 🚀 VARIÁVEIS OPCIONAIS (NÃO ESSENCIAIS)
# ================================================

# Modo debug
DEBUG=false

# Timeout para requisições externas (em ms)
AXIOS_TIMEOUT=10000
