# Variáveis de Configuração - COPIE PARA .env E PREENCHA COM VALORES REAIS

# Porta do Servidor
PORT=3001

# Ambiente
NODE_ENV=development

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/ecobot

# Credenciais Gmail (use senha de aplicação, não a senha da conta)
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app_gmail

# Tokens da API TagO.io (sensores ambientais)
TAGO_TOKEN_1=seu_token_1_aqui
TAGO_TOKEN_2=seu_token_2_aqui

# E-mails para receber alertas (separados por vírgula)
ALERT_EMAILS=email1@domain.com,email2@domain.com

# Origens CORS permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://seu-dominio.com
